{
  "default_prefix": "workspace/",
  "job_prefix": "apps/secret-audit/jobs/",
  "evidence_prefix": "apps/secret-audit/evidence/",
  "verification_prefix": "apps/secret-audit/verifications/",
  "report_prefix": "apps/secret-audit/reports/",
  "ignore_prefixes": [
    ".git/",
    "node_modules/",
    "dist/",
    "build/",
    ".venv/",
    "venv/",
    "apps/secret-audit/"
  ],
  "suspicious_file_names": [
    ".env",
    ".env.local",
    ".npmrc",
    ".pypirc",
    "credentials",
    "secrets",
    "id_rsa",
    "id_ed25519",
    ".pem",
    ".key"
  ],
  "secret_keys": [
    "polis/shared/jwt-signing-key",
    "cogent/local/discord",
    "cogent/local/github"
  ],
  "placeholder_markers": [
    "example",
    "changeme",
    "dummy",
    "test-token",
    "local-dev",
    "not-a-real-secret"
  ],
  "max_files_per_scan": 200,
  "max_inline_candidate_chars": 256
}
